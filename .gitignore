# ===================================
# Aadhivaraha Services - .gitignore
# PHP / XAMPP Website Project
# ===================================

# ----------------------------------
# OS Generated Files
# ----------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ----------------------------------
# IDE & Editor Files
# ----------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ----------------------------------
# PHP / Server Files
# ----------------------------------
# PHP error log
php_errors.log
error_log
*.log

# PHP environment config (keep secrets out of git)
.env
.env.local
.env.*.local
config.local.php
config/local.php

# PHP compiled files
*.cache

# ----------------------------------
# XAMPP / Apache / Server
# ----------------------------------
# XAMPP specific
xampp/
/tmp/
/temp/

# ----------------------------------
# Node / npm (if any build tools used later)
# ----------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ----------------------------------
# Build Output
# ----------------------------------
/dist/
/build/
/.next/

# ----------------------------------
# Sensitive / Private Files
# ----------------------------------
# Database exports
*.sql
*.sqlite
*.sqlite3
*.db

# Private keys & certificates
*.pem
*.key
*.crt
*.p12

# Backup files
*.bak
*.backup
*.old

# ----------------------------------
# Upload / User Generated Content
# (uncomment if uploads are stored in repo)
# ----------------------------------
# uploads/
# user-uploads/

# ----------------------------------
# Composer (PHP package manager)
# ----------------------------------
vendor/
composer.phar

# ----------------------------------
# Admin & SMTP Credentials (NEVER commit these)
# ----------------------------------
config/smtp.json
config/admin.php
